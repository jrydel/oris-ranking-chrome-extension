{
    "name": "oris-ranking-chrome-extension",
    "version": "1.0",
    "manifest_version": 3,
    "icons": {
        "128": "/images/icon.png"
    },
    "web_accessible_resources": [
        {
            "resources": ["images/icon.png"],
            "matches": ["<all_urls>"]
        }
    ],
    "content_scripts": [
        {
            "matches": ["https://oris.ceskyorientak.cz/PrehledPrihlasenych?id=*"],
            "js": ["entries.js"],
            "css": ["index.css"]
        },
        {
            "matches": ["https://oris.ceskyorientak.cz/Vysledky?id=*"],
            "js": ["results.js"],
            "css": ["index.css"]
        },
        {
            "matches": ["https://oris.ceskyorientak.cz/Startovka?id=*"],
            "js": ["startlist.js"],
            "css": ["index.css"]
        }
    ],
    "permissions": ["storage", "alarms"]
}
