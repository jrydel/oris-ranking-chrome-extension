{
	"name": "ORIS Ranking",
	"short_name": "ORIS Ranking",
	"description": "Zobrazuje aktuální RankC, RVP kategorie a předběžný zisk bodů na stránkách ORIS.",
	"version": "2.0.1",
	"manifest_version": 3,
	"minimum_chrome_version": "130",
	"homepage_url": "https://github.com/jrydel/oris-ranking-chrome-extension",
	"icons": {
		"16": "/images/icon.png",
		"48": "/images/icon.png",
		"128": "/images/icon.png"
	},
	"action": {
		"default_popup": "popup.html",
		"default_title": "ORIS Ranking",
		"default_icon": {
			"16": "/images/icon.png",
			"48": "/images/icon.png"
		}
	},
	"web_accessible_resources": [
		{
			"resources": ["images/icon.png"],
			"matches": ["https://oris.orientacnisporty.cz/*", "https://oris.ceskyorientak.cz/*"]
		}
	],
	"content_scripts": [
		{
			"matches": ["https://oris.orientacnisporty.cz/PrehledPrihlasenych?id=*", "https://oris.ceskyorientak.cz/PrehledPrihlasenych?id=*"],
			"js": ["entries.js"],
			"css": ["index.css"],
			"run_at": "document_idle"
		},
		{
			"matches": ["https://oris.orientacnisporty.cz/Vysledky?id=*", "https://oris.ceskyorientak.cz/Vysledky?id=*"],
			"js": ["results.js"],
			"css": ["index.css"],
			"run_at": "document_idle"
		},
		{
			"matches": ["https://oris.orientacnisporty.cz/Startovka?id=*", "https://oris.ceskyorientak.cz/Startovka?id=*"],
			"js": ["startlist.js"],
			"css": ["index.css"],
			"run_at": "document_idle"
		}
	]
}
