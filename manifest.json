{
	"name": "oris-ranking-chrome-extension",
	"description": "Zobrazuje aktuální RankC, RVP kategorie a předběžný zisk bodů na stránkách ORIS.",
	"version": "1.0.1",
	"manifest_version": 3,
	"minimum_chrome_version": "120",
	"icons": {
		"16": "/images/icon.png",
		"48": "/images/icon.png",
		"128": "/images/icon.png"
	},
	"web_accessible_resources": [
		{
			"resources": ["images/icon.png"],
			"matches": ["<all_urls>"]
		}
	],
	"content_scripts": [
		{
			"matches": ["https://oris.orientacnisporty.cz/PrehledPrihlasenych?id=*"],
			"js": ["entries.js"],
			"run_at": "document_idle"
		},
		{
			"matches": ["https://oris.orientacnisporty.cz/Vysledky?id=*"],
			"js": ["results.js"],
			"run_at": "document_idle"
		},
		{
			"matches": ["https://oris.orientacnisporty.cz/Startovka?id=*"],
			"js": ["startlist.js"],
			"run_at": "document_idle"
		}
	]
}
